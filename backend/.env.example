# Database provider: 'sqlite' (default, in-memory) or 'neon' (PostgreSQL via Neon)
DATA_PROVIDER=sqlite

# Required when DATA_PROVIDER=neon. Copy from your Neon project dashboard.
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# --- Neon sync settings (only used when DATA_PROVIDER=neon) ---

# Run incremental sync on startup. Recommended: true.
NEON_SYNC_ON_START=true

# Watch backend/src/data/ for file changes and sync them at runtime.
# Recommended: true in development, false in production.
NEON_WATCH_DATA_DIR=true

# Ignore hashes and re-seed every dataset on next startup. Useful for recovery.
NEON_FORCE_RESEED=false

# Max PostgreSQL connections in the pool. Neon free tier is low; keep this small.
NEON_POOL_MAX=5
